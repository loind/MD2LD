{
  "name": "lark-push",
  "version": "1.0.0",
  "description": "Push Markdown files to Lark Docs as a single binary",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "lark-push": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build src/index.ts --compile --outfile dist/lark-push"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/bun": "latest"
  }
}
